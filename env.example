# Copy to .env next to qkagent.exe or repo root (see README).

# Quicker web account (getquicker.net)
QUICKER_EMAIL=
QUICKER_PASSWORD=

# Optional: skip spawning a CDP helper and use this WebSocket / HTTP CDP URL directly.
# QKAGENT_CDP_URL=ws://127.0.0.1:9222/devtools/browser/...

# Executable that prints a CDP URL to stdout/stderr (default: qkagent-host).
# Must NOT be the same name as this CLI (qkagent.exe) or session new would spawn itself.
# Example if your browser launcher is still named qkagent.exe on disk: use full path to that file.
# QKAGENT_COMMAND=C:\Path\To\browser-launcher.exe

# Extra arguments passed after the command (space-separated string).
# QKAGENT_SESSION_NEW_ARGS=

# Default session id when --id is omitted (default: default).
# QUICKER_AGENT_SESSION_ID=default

# Override session JSON directory (default: %LOCALAPPDATA%\quicker-agent\sessions on Windows).
# QUICKER_AGENT_SESSION_DIR=

# --- action-doc upload (optional; only if default page/selectors do not match the site) ---
# Page after login; use {code} or {0} for shared action id.
# QKAGENT_ACTION_DOC_PAGE_URL=https://getquicker.net/Sharedaction?code={code}
# CSS: click before editor appears (e.g. owner-only "edit intro" control).
# QKAGENT_ACTION_DOC_OPEN_EDITOR_SELECTOR=
# CSS passed to waitForSelector for Summernote root / .note-editable.
# QKAGENT_ACTION_DOC_EDITOR_SELECTOR=#summernote, .note-editable
# Save button accessible name (Chinese UI default).
# QKAGENT_ACTION_DOC_SAVE_BUTTON_TEXT=保存
# CSS fallback for save control.
# QKAGENT_ACTION_DOC_SAVE_SELECTOR=
