# Copy to .env next to qkagent.exe or repo root (see README).

# Quicker web account (getquicker.net) — must own the shared action to edit its intro.
QUICKER_EMAIL=
QUICKER_PASSWORD=

# Optional: run Chromium without a window (1 / true / yes).
# QKAGENT_HEADLESS=false

# --- action-doc upload (optional; only if default page/selectors do not match the site) ---
# Page after login; use {code} or {0} for shared action id.
# QKAGENT_ACTION_DOC_PAGE_URL=https://getquicker.net/Sharedaction?code={code}
# CSS: click before editor appears (e.g. owner-only control).
# QKAGENT_ACTION_DOC_OPEN_EDITOR_SELECTOR=
# CSS passed to waitForSelector for Summernote root / .note-editable.
# QKAGENT_ACTION_DOC_EDITOR_SELECTOR=#summernote, .note-editable
# Save button accessible name (Chinese UI default).
# QKAGENT_ACTION_DOC_SAVE_BUTTON_TEXT=保存
# CSS fallback for save control.
# QKAGENT_ACTION_DOC_SAVE_SELECTOR=
