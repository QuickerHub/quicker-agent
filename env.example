# Copy to .env next to qkagent.exe or repo root (see README).

# Quicker web account (getquicker.net) — must own the shared action to edit its intro.
QUICKER_EMAIL=
QUICKER_PASSWORD=

# Optional: run browser without a window (1 / true / yes).
# QKAGENT_HEADLESS=false

# Persistent login profile (cookies). Default: %LOCALAPPDATA%\qkagent\browser-profile
# QKAGENT_PROFILE_DIR=

# Local action descriptions (pull/push workflow). Default: %USERPROFILE%\.quicker\actions\<sharedId>\info.html
# QKAGENT_ACTIONS_ROOT=

# Force browser: chrome | msedge | edge | chromium (bundled). Default: try chrome → msedge → chromium.
# QKAGENT_BROWSER_CHANNEL=
